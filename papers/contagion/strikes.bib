@article{cramton1992,
  title = {Strikes and Holdouts in Wage Bargaining: {{Theory}} and Data},
  author = {Cramton, Peter C. and Tracy, Joseph S.},
  date = {1992},
  journaltitle = {The American Economic Review},
  volume = {82},
